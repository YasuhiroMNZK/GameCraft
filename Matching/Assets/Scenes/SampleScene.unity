  m_Script: {fileID: 11500000, guid: faa2bad9e6b32c747a3d5a4080685d30, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::StepManager
  chatManager: {fileID: 275763992}
  dialogues:
  - rightPlayer: "\u3088\u308D\u3057\u304F\u304A\u9858\u3044\u3057\u307E\u3059\u3002\u6E29\u6CC9\u304C\u3059\u304D\u306A\u3093\u3067\u3059\u306D\u3002"
    rightNpc: "\u305D\u3046\u306A\u306E\uFF01<color=#FF0021>\u6E29\u6CC9\u65C5\u884C</color>\u3059\u304D\u306A\u306E\u306B\u3001\u7ACB\u3061\u5165\u308A\u62D2\u5426\u3055\u308C\u308B\u3053\u3068\u304C\u591A\u304F\u3066\u60B2\u3057\u3044\u2026\u3002\u306A\u306B\u3082<color=#FF0021>\u30C0\u30E1\u306A\u3053\u3068</color>\u3057\u3066\u306A\u3044\u306E\u306B\u3072\u3069\u3044\u3068\u304A\u3082\u308F\u306A\u3044\u2049\r\n"
    wrongPlayer: "\u79C1\u3082\u8FD4\u4FE1\u65E9\u3044\u307B\u3046\u3067\u3059\u3002\u3088\u308D\u3057\u304F\u304A\u9858\u3044\u3057\u307E\u3059\u3002"
    wrongNpc: "\u624B\u5148\u304C\u5668\u7528\u3060\u304B\u3089\u3001\u3059\u3050\u8FD4\u4FE1\u3067\u304D\u308B\u3088\u30FC\uFF01\u306A\u306B\u8A71\u3059\uFF1F"
  - rightPlayer: "\u3069\u3046\u3057\u3066\u62D2\u5426\u3055\u308C\u308B\u306E\uFF1F"
    rightNpc: "\u898B\u305F\u76EE\u304C\u30C0\u30E1\u306A\u3093\u3060\u3063\u3066\u2026\u3002\u307E\u3042\u79C1\u306F<color=#0028FF>\u9B54\u6CD5\u6559\u5F92</color>\u306E<color=#FF0021>\u7814\u7A76</color>\u3067\u751F\u307F\u51FA\u3055\u308C\u305F\u751F\u304D\u7269\u3060\u304B\u3089\u3001\u307F\u3093\u306A\u304B\u3089\u898B\u305F\u3089\u5909\u306A\u898B\u305F\u76EE\u306A\u306E\u304B\u306A\u3002"
    wrongPlayer: "\u305D\u308C\u306F\u3072\u3069\u3044\u3067\u3059\u306D\u2026"
    wrongNpc: "\u624B\u5148\u304C\u5668\u7528\u3060\u304B\u3089\u3001\u3059\u3050\u8FD4\u4FE1\u3067\u304D\u308B\u3088\u30FC\uFF01\u306A\u306B\u8A71\u3059\uFF1F"
  - rightPlayer: "\u9B54\u6CD5\u6559\u5F92\uFF1F\u7814\u7A76\u3063\u3066\u306A\u306B\uFF1F"
    rightNpc: "<color=#0028FF>\u9B54\u6CD5\u6559</color>\u306F\u73FE\u4EE3\u306E\u4E8C\u5927\u5B97\u6D3E\u306E\u4E00\u3064\u3060\u3088\u3002\u79C1\u306F\u9B54\u6CD5\u6559\u5F92\u304C\u5927\u5ACC\u3044\u306A\u306E\uFF01\u79D1\u5B66\u6559\u306E\u3084\u3064\u3089\u306E\u79D1\u5B66\u65BD\u8A2D\u3092<color=#FF0021>\u8972\u3046</color>\u305F\u3081\u306B\u8EDF\u4F53\u9B54\u7269\u306E\u7814\u7A76\u3092\u3057\u3066\u305F\u307F\u305F\u3044\u3002\u305D\u308C\u306E\u526F\u7523\u7269\u304C\u308F\u305F\u3057\uFF01"
    wrongPlayer: "\u305D\u3046\u306A\u3093\u3060\u3002\u5927\u5909\u3067\u3059\u306D\u2026\u3002"
    wrongNpc: "\u624B\u5148\u304C\u5668\u7528\u3060\u304B\u3089\u3001\u3059\u3050\u8FD4\u4FE1\u3067\u304D\u308B\u3088\u30FC\uFF01\u306A\u306B\u8A71\u3059\uFF1F"
  - rightPlayer: "\u8EDF\u4F53\u9B54\u7269\u3063\u3066\uFF1F"
    rightNpc: "\u9AA8\u3092\u6301\u305F\u306A\u3044\u9B54\u7269\u3060\u3088\uFF01\u30BF\u30B3\u3068\u304B\u30CA\u30E1\u30AF\u30B8\u3068\u304B\uFF01<color=#FF0021>\u306C\u3081\u306C\u3081</color>\u3057\u3066\u308B\u306E\u304C\u591A\u3044\u304B\u306A\u3002\u79C1\u3082\u306C\u3081\u306C\u3081\u3057\u3066\u308B\u304B\u3089\u3001\u3042\u3093\u307E\u308A\u898B\u305F\u76EE\u306B\u81EA\u4FE1\u304C\u306A\u3044\u306A\u3042\u2026\u3002"
    wrongPlayer: "\u3078\u30FC\u305D\u3093\u306A\u3053\u3068\u306B\u306A\u3063\u3066\u3093\u3060\u3002"
    wrongNpc: "\u624B\u5148\u304C\u5668\u7528\u3060\u304B\u3089\u3001\u3059\u3050\u8FD4\u4FE1\u3067\u304D\u308B\u3088\u30FC\uFF01\u306A\u306B\u8A71\u3059\uFF1F"
